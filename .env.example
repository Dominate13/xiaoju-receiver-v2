# =============================================
# xiaoju-receiver-v2 配置文件示例
# 复制此文件为 .env 并填入实际值
# =============================================

# ============ 服务配置 ============
SERVICE_PORT=8100

# ============ 小桔充电平台密钥 ============
# 从小桔充电开放平台获取
XJ_OPERATOR_ID=your_operator_id
XJ_OPERATOR_SECRET=your_operator_secret
XJ_DATA_SECRET=your_aes_secret_key_32chars
XJ_DATA_SECRET_IV=your_aes_iv_16chars
XJ_SIG_SECRET=your_hmac_signature_secret

# ============ 数据库配置 ============
DB_URL=sqlite:///./data/xiaoju.db

# ============ 后台管理认证 ============
# 首次部署请务必修改默认密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# ============ 氚云 OpenAPI 配置 ============
# 从氚云开放平台获取
H3YUN_ENGINE_CODE=your_engine_code
H3YUN_ENGINE_SECRET=your_engine_secret
H3YUN_SCHEMA_CODE=your_schema_code

# ============ 同步任务配置 ============
SYNC_INTERVAL_SECONDS=30
SYNC_BATCH_SIZE=10
SYNC_MAX_RETRY=3

# ============ 告警配置（可选）============
# 钉钉群机器人 webhook 地址
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# ============ 健康检查配置 ============
HEALTH_CHECK_INTERVAL=60
HEALTH_CHECK_THRESHOLD=3
